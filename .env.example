DATABASE_URL="postgresql://gymmate:gymmate@localhost:5432/gymmate"
AUTH_SECRET="change-me-to-a-long-random-string-at-least-16-chars"
DEMO_USER_EMAIL="demo@gymmate.local"
DEMO_USER_PASSWORD="demo123"
NEXT_PUBLIC_USE_API="false"

# Kafka logging (optional — app works without it)
KAFKA_BROKERS="localhost:9092"
KAFKA_LOG_TOPIC="gymmate-logs"
KAFKA_CLIENT_ID="gymmate-crm"
# KAFKA_ENABLED="false"

# FatSecret Platform API (optional — live food search fallback)
# FATSECRET_CLIENT_ID=
# FATSECRET_CLIENT_SECRET=
# FATSECRET_ENABLED="true"
# FATSECRET_SCOPE="basic"
# FATSECRET_REGION=
