generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  STRENGTH
}

enum MuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
}

enum WorkoutLabel {
  HEAVY
  MEDIUM
  LIGHT
  CARDIO
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ArticleCategory {
  NUTRITION
  TRAINING
  RECOVERY
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String
  lastName      String     @default("")
  phone         String     @default("")
  goal          Goal       @default(MUSCLE_GAIN)
  startWeight   Float      @default(0)
  currentWeight Float      @default(0)
  status        UserStatus @default(ACTIVE)
  inactiveSince DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  workouts    Workout[]
  bodyMetrics BodyMetric[]
}

model Exercise {
  id           String      @id @default(cuid())
  name         String
  muscleGroup  MuscleGroup
  instructions String?

  sets WorkoutSet[]

  @@unique([name, muscleGroup])
}

model Workout {
  id        String       @id @default(cuid())
  userId    String
  date      DateTime     @default(now())
  label     WorkoutLabel @default(MEDIUM)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]

  @@index([userId, date])
}

model WorkoutSet {
  id           String @id @default(cuid())
  workoutId    String
  exerciseId   String
  exerciseName String
  setNumber    Int
  weight       Float
  reps         Int

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId])
}

model BodyMetric {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @default(now())
  weight Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Article {
  id        String          @id @default(cuid())
  title     String
  slug      String          @unique
  content   String
  category  ArticleCategory
  createdAt DateTime        @default(now())
}
