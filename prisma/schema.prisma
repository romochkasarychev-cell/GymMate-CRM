generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  STRENGTH
}

enum MuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
}

enum WorkoutLabel {
  HEAVY
  MEDIUM
  LIGHT
  CARDIO
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  USER
  ADMIN
}

enum ArticleCategory {
  NUTRITION
  TRAINING
  RECOVERY
}

enum MeasurementKind {
  SHOULDERS
  CHEST
  WAIST
  HIPS
  ARM_RIGHT
  ARM_LEFT
  LEG_RIGHT
  LEG_LEFT
}

enum FoodSource {
  BASKOVSKY
  OPEN_FOOD_FACTS
  MANUAL
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String
  lastName      String     @default("")
  phone         String     @default("")
  goal          Goal       @default(MUSCLE_GAIN)
  startWeight   Float      @default(0)
  currentWeight Float      @default(0)
  startShoulders Float     @default(0)
  startChest     Float     @default(0)
  startWaist     Float     @default(0)
  startHips      Float     @default(0)
  startArmRight  Float     @default(0)
  startArmLeft   Float     @default(0)
  startLegRight  Float     @default(0)
  startLegLeft   Float     @default(0)
  currentShoulders Float   @default(0)
  currentChest     Float   @default(0)
  currentWaist     Float   @default(0)
  currentHips      Float   @default(0)
  currentArmRight  Float   @default(0)
  currentArmLeft   Float   @default(0)
  currentLegRight  Float   @default(0)
  currentLegLeft   Float   @default(0)
  status        UserStatus @default(ACTIVE)
  role          UserRole   @default(USER)
  inactiveSince DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  workouts           Workout[]
  bodyMetrics          BodyMetric[]
  measurementMetrics   MeasurementMetric[]
}

model MeasurementMetric {
  id     String           @id @default(cuid())
  userId String
  date   DateTime
  kind   MeasurementKind
  value  Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, date])
}

model Exercise {
  id           String      @id @default(cuid())
  name         String
  muscleGroup  MuscleGroup
  instructions String?

  sets WorkoutSet[]

  @@unique([name, muscleGroup])
}

model Workout {
  id        String       @id @default(cuid())
  userId    String
  date      DateTime     @default(now())
  label     WorkoutLabel @default(MEDIUM)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]

  @@index([userId, date])
}

model WorkoutSet {
  id           String @id @default(cuid())
  workoutId    String
  exerciseId   String
  exerciseName String
  setNumber    Int
  weight       Float
  reps         Int

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId])
}

model BodyMetric {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @default(now())
  weight Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Article {
  id        String          @id @default(cuid())
  title     String
  slug      String          @unique
  content   String
  category  ArticleCategory
  createdAt DateTime        @default(now())
}

model FoodProduct {
  id             String     @id @default(cuid())
  name           String
  nameNormalized String
  category       String?
  kcal           Float
  protein        Float      @default(0)
  fat            Float      @default(0)
  carbs          Float      @default(0)
  barcode        String?    @unique
  brand          String?
  source         FoodSource
  externalId     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([name, source, brand])
  @@index([nameNormalized])
  @@index([source])
}

model ApiLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  level      String
  message    String
  route      String?
  method     String?
  path       String?
  status     Int?
  durationMs Int?
  userEmail  String?
  context    Json?
  createdAt  DateTime @default(now())

  @@index([timestamp(sort: Desc)])
  @@index([level])
}
